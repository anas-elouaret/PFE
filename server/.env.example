# Server
PORT=5000
NODE_ENV=development

# Frontend origin (for CORS)
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/fullstack-with-jadara

# JWT
JWT_SECRET=change-this-to-a-strong-secret-in-production

# Email — pick one method
# 1) SMTP (Gmail, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@growstack.app

# 2) Resend
# RESEND_API_KEY=re_xxxxx

# 3) Mailtrap (development)
# MAILTRAP_HOST=smtp.mailtrap.io
# MAILTRAP_PORT=587
# MAILTRAP_USER=your-mailtrap-user
# MAILTRAP_PASS=your-mailtrap-pass
